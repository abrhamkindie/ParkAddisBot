# ---- App ----
APP_NAME=ParkAddis
NODE_ENV=development
PORT=3000
# Public base URL of this backend (used for Mini App + Chapa callbacks later)
PUBLIC_URL=http://localhost:3000

# ---- Telegram ----
# Get this from @BotFather
BOT_TOKEN=123456:replace-me
# Username of the bot (no @), used to build Mini App links later
BOT_USERNAME=ParkAddisBot

# ---- Database ----
# Matches docker-compose.yml defaults
DATABASE_URL=postgres://parking:parking@localhost:5433/parking
PGSSL=false

# ---- Search defaults ----
DEFAULT_SEARCH_RADIUS_M=2000
MAX_SEARCH_RESULTS=8
# Tile source for the in-chat nearby map (override for a provider with a usage
# allowance in production). Defaults to the public OpenStreetMap tiles.
# MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# ---- Business ----
# Default platform commission (can be overridden at runtime in the settings table)
DEFAULT_COMMISSION_PERCENT=15
CURRENCY=ETB

# ---- Admin / JWT (used by the admin dashboard API) ----
JWT_SECRET=change-me-in-production
# JWT token expiry (e.g., '1h', '24h', '7d')
JWT_EXPIRY=24h
# Bootstrap admin credentials (used on first setup)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=changeme

# ---- Chapa Payment Gateway ----
# Get your API keys from https://dashboard.chapa.co/aqa/settings
# Chapa supports Telebirr, CBE Birr, and card payments in Ethiopia
#
# For sandbox testing:
# 1. Create a Chapa account at https://dashboard.chapa.co
# 2. Go to Settings > API Keys
# 3. Copy your Secret Key (starts with 'CHASECK-')
#
# For webhook configuration:
# - Set PUBLIC_URL to your public server URL (ngrok for local dev)
# - Configure webhook URL in Chapa dashboard: {PUBLIC_URL}/api/payments/chapa/webhook
# - CHAPA_WEBHOOK_SECRET is optional (for webhook signature verification)
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=

# ---- Smart Notifications ----
# Enable automatic booking reminders, payment warnings, and check-in prompts
ENABLE_NOTIFICATIONS=true
# How often to check for pending notifications (in minutes)
NOTIFICATION_CHECK_INTERVAL=5

# ---- Telegram Webhook (Production) ----
# Mode: 'polling' for development, 'webhook' for production
TELEGRAM_MODE=polling
# Required when TELEGRAM_MODE=webhook
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook/telegram
# Optional: Secret token for webhook verification
WEBHOOK_SECRET=

# ---- Security ----
# CORS allowed origins (comma-separated, or * for all)
CORS_ORIGINS=https://yourdomain.com,https://t.me
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # max requests per IP per window

# ---- Logging ----
# Log level: debug, info, warn, error
LOG_LEVEL=info
# Log format: 'pretty' for development, 'json' for production
LOG_FORMAT=json

# ---- Production Notes ----
# 1. Never commit .env to git
# 2. Use strong passwords in production
# 3. Set NODE_ENV=production for production deployments
# 4. Enable PGSSL=true for remote databases
# 5. Use webhook mode in production for better reliability
