# ---- App ----
APP_NAME=ParkAddis
NODE_ENV=development
PORT=3000
# Public base URL of this backend (used for Mini App + Chapa callbacks later)
PUBLIC_URL=http://localhost:3000

# ---- Telegram ----
# Get this from @BotFather
BOT_TOKEN=123456:replace-me
# Username of the bot (no @), used to build Mini App links later
BOT_USERNAME=ParkAddisBot

# ---- Database ----
# Matches docker-compose.yml defaults
DATABASE_URL=postgres://parking:parking@localhost:5433/parking
PGSSL=false

# ---- Search defaults ----
DEFAULT_SEARCH_RADIUS_M=2000
MAX_SEARCH_RESULTS=8
# Nearby spots dropped as native map pins in chat (rest go on the map button).
MAX_INLINE_PINS=5

# ---- Business ----
# Default platform commission (can be overridden at runtime in the settings table)
DEFAULT_COMMISSION_PERCENT=15
CURRENCY=ETB

# ---- Admin / JWT (used later by the dashboard) ----
JWT_SECRET=change-me-in-production
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=changeme

# ---- Chapa (added in the payments step) ----
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=
